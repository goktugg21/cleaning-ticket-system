# Django
DJANGO_SECRET_KEY=change-me-generate-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# DEBUG / INFO / WARNING / ERROR / CRITICAL — drives root + per-app loggers.
DJANGO_LOG_LEVEL=INFO

# Frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Production HTTPS security
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False
DJANGO_USE_X_FORWARDED_PROTO=False

# Database
POSTGRES_DB=cleaning_ticket_db
POSTGRES_USER=cleaning_ticket_user
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# API throttling
DRF_THROTTLE_ANON_RATE=60/minute
DRF_THROTTLE_USER_RATE=5000/hour
DRF_THROTTLE_AUTH_TOKEN_RATE=20/minute
DRF_THROTTLE_AUTH_TOKEN_REFRESH_RATE=60/minute

# Email — defaults route through the MailHog service in docker-compose.yml.
# Inspect captured emails at http://localhost:8025. For production replace
# with real SMTP credentials (see .env.production.example).
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=no-reply@example.com

# ---- Sentry (optional, set DSN to enable) ----
# Empty DSN keeps the SDK as a no-op — zero overhead. Frontend env vars
# live in frontend/.env.example because Vite only exposes VITE_*-prefixed
# variables to the browser bundle.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.0
# SENTRY_RELEASE=  # optional, set to git SHA via CI

# Celery (async email)
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_ALWAYS_EAGER=False
NOTIFICATION_QUEUED_TIMEOUT_MINUTES=30

# Invitations
INVITATION_TTL_DAYS=7
INVITATION_ACCEPT_FRONTEND_URL=http://localhost:5173/invite/accept?token={token}

# Password reset
PASSWORD_RESET_FRONTEND_URL=http://localhost:5173/password/reset/confirm?uid={uid}&token={token}
