VITE_API_BASE_URL=http://localhost:8000/api

# ---- Sentry (optional, set DSN to enable) ----
# Vite only exposes VITE_*-prefixed env vars to the browser bundle.
# Empty DSN keeps the SDK as a no-op.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_TRACES_SAMPLE_RATE=0.0
# VITE_SENTRY_RELEASE=  # optional, set to git SHA via CI

# ---- Demo helper UI (Sprint 16) ----
# When "true", the login page shows quick-fill cards for every account
# created by `python manage.py seed_demo_data` (super admin, company
# admin, building managers, customer users) plus a hint that the shared
# password is Demo12345!. The flag is OPT-IN: leaving it unset (or
# anything other than the literal string "true") hides the cards
# completely. NEVER set this to "true" in a production .env.production —
# the demo accounts use a well-known shared password.
VITE_DEMO_MODE=false
