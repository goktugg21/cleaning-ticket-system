# ============================================================
# Production .env example for the cleaning-ticket-system stack.
#
# Topology:
#   Browser (HTTPS)
#     -> NGINX Proxy Manager / firewall  (TLS terminates here)
#       -> frontend container :80        (nginx, serves SPA + proxies /api/)
#         -> backend container :8000     (gunicorn, internal HTTP)
#
# The app does NOT terminate TLS. NPM owns certificates, redirects,
# and HSTS. Django only needs to TRUST the proxy headers — see
# DJANGO_USE_X_FORWARDED_PROTO below.
#
# All real secrets stay out of the repository. Replace every
# `replace-with-...` placeholder with operator-managed values via
# the orchestrator's secret store, never a committed file.
# See docs/deployment.md for the full bootstrap.
# ============================================================

# ---- Django ----
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-key

# Public hostname(s) the proxy forwards as Host. Do NOT add
# localhost / 127.0.0.1 here — the production-settings validator
# (backend/config/security.py) rejects those entries when
# DJANGO_DEBUG=False. The internal docker healthcheck no longer
# routes through Django's host-validation gate (it uses a TCP
# socket probe), so an internal hostname is not required.
DJANGO_ALLOWED_HOSTS=example.com,www.example.com

# DEBUG / INFO / WARNING / ERROR / CRITICAL — production should run
# at WARNING or higher so 200-OK request traffic does not pollute
# logs.
DJANGO_LOG_LEVEL=WARNING

# ---- Frontend / API origins ----
CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com
CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# ---- HTTPS / proxy security ----
# DJANGO_SECURE_SSL_REDIRECT=False because NPM owns the HTTP -> HTTPS
# redirect upstream. Setting this to True here would cause Django to
# redirect again on every request that arrived over the internal HTTP
# hop, producing a redirect loop or mixed-protocol surprise.
DJANGO_SECURE_SSL_REDIRECT=False

# Trust X-Forwarded-Proto from the upstream proxy so request.is_secure()
# returns True for traffic that NPM forwarded as HTTPS. This wires
# settings.SECURE_PROXY_SSL_HEADER. Required for cookie security flags
# and CSRF to behave correctly behind the proxy.
DJANGO_USE_X_FORWARDED_PROTO=True

# Cookie security: keep these True so session/CSRF cookies are only
# sent over HTTPS as the BROWSER sees them (NPM upstream). The value
# above (DJANGO_USE_X_FORWARDED_PROTO=True) ensures Django recognises
# proxied requests as secure and therefore sets these cookies.
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True

# HSTS:
#   Default 0 (disabled at the Django layer). NPM is the right place
#   to own HSTS — set the policy in NPM's host config. Setting HSTS
#   from Django when NPM also sets it just doubles the header.
#   Operators who explicitly want app-level HSTS (e.g. defense in
#   depth) can flip these to non-zero values.
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False

# ---- PostgreSQL ----
# db is container-internal in docker-compose.prod.yml — no public
# port. Backend reaches it on the docker network as host=db.
POSTGRES_DB=cleaning_ticket_db
POSTGRES_USER=cleaning_ticket_user
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---- Redis ----
# Same posture as Postgres: container-internal only.
REDIS_URL=redis://redis:6379/0

# ---- Email / SMTP via Amazon SES ----
# Bootstrap (one-time, in the AWS console):
#   1. Verify the sending domain (or single From address) in SES.
#   2. Create IAM SMTP credentials — these are NOT raw IAM access
#      keys. Use the "Create SMTP credentials" button under the SES
#      "SMTP settings" page; the user/password it generates are
#      what go below.
#   3. If your account is still in the SES sandbox, request
#      production access; otherwise SES will only deliver to
#      verified addresses.
# Replace <region> with the SES region you verified the domain in,
# e.g. eu-west-1, us-east-1.
EMAIL_HOST=email-smtp.<region>.amazonaws.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=replace-with-ses-smtp-user
EMAIL_HOST_PASSWORD=replace-with-ses-smtp-password
DEFAULT_FROM_EMAIL=no-reply@your-domain.example

# ---- Frontend Docker build / runtime ----
VITE_API_BASE_URL=/api
FRONTEND_PORT=80

# ---- API throttling ----
DRF_THROTTLE_ANON_RATE=60/minute
DRF_THROTTLE_USER_RATE=5000/hour
DRF_THROTTLE_AUTH_TOKEN_RATE=20/minute
DRF_THROTTLE_AUTH_TOKEN_REFRESH_RATE=60/minute

# ---- Gunicorn ----
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

# ---- Sentry (optional, set DSN to enable) ----
# Empty DSN keeps the SDK as a no-op — zero overhead. Frontend
# Sentry env vars (VITE_SENTRY_*) live in frontend/.env.example.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_RELEASE=  # optional, set to git SHA via CI

# ---- Celery (async email) ----
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_ALWAYS_EAGER=False
NOTIFICATION_QUEUED_TIMEOUT_MINUTES=30

# ---- Invitations ----
INVITATION_TTL_DAYS=7
INVITATION_ACCEPT_FRONTEND_URL=https://example.com/invite/accept?token={token}
